{
  "version": 1,
  "name": "Open Brain Shortcuts",
  "shortcuts": [
    {
      "name": "Capture Thought",
      "description": "Capture a thought to Open Brain with voice dictation",
      "method": "POST",
      "url": "https://YOUR_TAILSCALE_HOSTNAME:3001/api/capture",
      "headers": [
        {
          "key": "Authorization",
          "value": "Bearer YOUR_API_TOKEN"
        },
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "bodyType": "custom_text",
      "bodyContent": "{\"text\": \"{text}\", \"context\": \"personal\"}",
      "variables": [
        {
          "key": "text",
          "type": "text_input",
          "title": "What are you thinking?",
          "multiline": true
        }
      ],
      "responseHandling": {
        "successMessage": "Thought captured!",
        "showResponse": true
      },
      "icon": "brain",
      "color": "#6366f1"
    },
    {
      "name": "Capture Family Thought",
