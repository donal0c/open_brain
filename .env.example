# Supabase PostgreSQL connection string (use transaction pooler, port 6543)
SUPABASE_DB_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# OpenAI API key for text-embedding-3-small
OPENAI_API_KEY=sk-...

# AWS credentials for Bedrock (Claude Haiku metadata extraction)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# Optional: Override Bedrock model ID (default: us.anthropic.claude-sonnet-4-6)
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Optional: HTTP API (enables POST /api/capture, GET /api/search, GET /api/recent, PWA client)
# Set API_TOKEN to enable the HTTP server alongside the MCP stdio transport
# API_TOKEN=your-secret-bearer-token
# HTTP_PORT=3001
# OPEN_BRAIN_ENABLE_ADMIN_HTTP=true   # Optional: expose update/archive/timeline/summarize HTTP endpoints
