{
  "name": "open-brain",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server for personal thought capture and semantic retrieval",
  "bin": {
    "open-brain": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "setup-db": "tsx scripts/setup-db.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "openai": "^4.80.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
